---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import "../../styles/global.css";

import { aboutData } from "../../data/aboutData.ts";

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} | Blog`}>
	<article class="min-h-screen w-full pt-12 desktop:pt-0 mx-auto">
		<div class="mb-8 desktop:pl-26 px-4 desktop:px-0 desktop:pr-16">
			<a href="/blogs" class="pt-10 text-xs font-mono text-blue-500 hover:text-blue-600 transition-colors uppercase tracking-widest flex items-center gap-2 mb-6">
				<span class="text-lg">←</span> Back to Blogs
			</a>
    </div>
		
		<div class="mb-8 desktop:pl-26 px-4 desktop:px-0 desktop:pr-16 pt-6 border-t border-gray-200">
			<h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-2 leading-tight ">
				{post.data.title}
			</h1>
      
      <div class="flex items-center gap-4 text-xs font-mono text-gray-500 uppercase tracking-widest mb-6">
				<time datetime={post.data.pubDate.toISOString()}>
					{post.data.pubDate.toLocaleDateString('en-us', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</time>
				{post.data.updatedDate && (
					<span class="italic">(Updated on {post.data.updatedDate.toLocaleDateString()})</span>
				)}
			</div>
			
			<div class="flex flex-wrap gap-2 mb-4">
				{post.data.tags.map(tag => (
					<span class="px-2.5 py-1 bg-gray-50 border border-gray-100 rounded-md text-[10px] font-bold uppercase tracking-wider text-gray-700">
						#{tag}
					</span>
				))}
			</div>
      
		</div>

    <div class="desktop:pl-26 desktop:pr-16 px-4 desktop:px-0 ">
      {post.data.heroImage && (
        <div class="w-full h-[40vh] md:h-[50vh] rounded-xl overflow-hidden mb-12 ">
          <img src={post.data.heroImage} alt="" class="w-full h-full object-cover" />
        </div>
      )}
    </div>
    
    <div class="desktop:pl-26 desktop:pr-16 px-4 py-10 border-t border-gray-200">
      <div 
          id="markdown-body" 
          class="prose prose-lg prose-gray max-w-none 
                  prose-headings:text-gray-900 prose-headings:font-bold 
                  prose-p:text-gray-700 prose-p:leading-relaxed 
                  prose-a:text-blue-500 hover:prose-a:text-blue-600 
                  prose-img:rounded-xl prose-img:shadow-lg"
      >
          <Content />
      </div>
    </div>

		<div class="py-10 px-4 desktop:px-0 border-t border-gray-200">
			<div class="flex justify-between items-center desktop:pl-26 desktop:pr-16">
				<div class="flex items-center gap-4">
					<div class="w-12 h-12 rounded-full bg-gray-900 flex items-center justify-center text-white font-bold">
						AP
					</div>
					<div>
            <p class="text-sm font-bold text-gray-900">{aboutData.name}</p>
            <p class="text-xs text-gray-500">{aboutData.role}</p>
					</div>
				</div>
				<button 
					onClick="window.scrollTo({top: 0, behavior: 'smooth'})"
					class="text-xs font-mono text-gray-400 hover:text-gray-900 transition-colors uppercase tracking-widest"
				>
					// Back to Top
				</button>
			</div>
		</div>
	</article>
</Layout>

